{
  "name": "brisk-tab",
  "author": "SummersDay",
  "version": "0.5.0",
  "description": "An alt blank page for your browser",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
